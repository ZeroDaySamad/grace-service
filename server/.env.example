# --- CONFIGURATION SERVEUR ---
PORT=5000
NODE_ENV=production

# --- BASE DE DONNÉES (NEON / POSTGRESQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=

# --- AUTHENTIFICATION ---
JWT_SECRET=votre_secret_tres_long_et_aleatoire

# --- IMAGES (IMGBB - Actuel) ---
IMGBB_API_KEY=

# --- IMAGES (CLOUDINARY - Recommandé pour Production) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- FRONTEND (CORS) ---
# L'URL de votre site frontend déployé (ex: https://graceservice.render.com)
FRONTEND_URL=
